# ── Data: raw source files (large, regenerated by pipeline) ──────────────────
data/raw/*.csv
data/raw/*.xlsx
data/logs/

# ── Keep these (Streamlit Cloud needs them on first deploy) ──────────────────
# data/contracts.db         → committed
# data/processed/*.csv      → committed
# data/processed/*.json     → committed
# data/raw/*.json           → committed (NHL API caches)
# models/xgb.pkl            → committed

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
dist/
build/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/

# ── Env / secrets ─────────────────────────────────────────────────────────────
.env
.env.*
secrets.toml

# ── Incoming context dump (R project files — not part of app) ─────────────────
incoming/

# ── Temp / OS ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.tmp
C:Temp*.txt
.claude/

# ── Large / redundant model files ─────────────────────────────────────────────
models/xgb_tuned.pkl
data/raw/contracts_cache.json.bak
